# =============================================================================
# PromptLab — LLM Provider Configuration
# =============================================================================
# Copy this file to .env.local and fill in your API keys.
# At least one provider must be configured for LLM features to work.

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
# Required for using GPT models (gpt-4o-mini, gpt-4o, etc.)
OPENAI_API_KEY=sk-xxx
# Optional — defaults to https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# 通义千问 (DashScope)
# ---------------------------------------------------------------------------
# Required for using Qwen models (qwen-turbo, qwen-plus, qwen-max, etc.)
DASHSCOPE_API_KEY=sk-xxx
